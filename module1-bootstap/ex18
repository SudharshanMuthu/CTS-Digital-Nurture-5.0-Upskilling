<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Exercise 18</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">

    <h1 class="text-center text-primary mb-5">
        Bootstrap JavaScript Plugins
    </h1>

    <!-- Exercise 18.1 -->

    <h2 class="mb-3">
        Modal Popup Example
    </h2>

    <button
        class="btn btn-primary"
        data-bs-toggle="modal"
        data-bs-target="#eventModal">

        Open Event Details

    </button>

    <!-- Modal -->

    <div class="modal fade" id="eventModal">

        <div class="modal-dialog">

            <div class="modal-content">

                <div class="modal-header">

                    <h5 class="modal-title">
                        Community Event
                    </h5>

                    <button
                        class="btn-close"
                        data-bs-dismiss="modal">
                    </button>

                </div>

                <div class="modal-body">

                    Welcome to the Annual Community Event 2026.

                </div>

                <div class="modal-footer">

                    <button
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">

                        Close

                    </button>

                </div>

            </div>

        </div>

    </div>

    <hr class="my-5">

    <!-- Exercise 18.2 -->

    <h2 class="mb-3">
        Accordion Example
    </h2>

    <div class="accordion" id="eventAccordion">

        <div class="accordion-item">

            <h2 class="accordion-header">

                <button
                    class="accordion-button"
                    data-bs-toggle="collapse"
                    data-bs-target="#event1">

                    Music Festival

                </button>

            </h2>

            <div
                id="event1"
                class="accordion-collapse collapse show">

                <div class="accordion-body">

                    Community music festival details.

                </div>

            </div>

        </div>

        <div class="accordion-item">

            <h2 class="accordion-header">

                <button
                    class="accordion-button collapsed"
                    data-bs-toggle="collapse"
                    data-bs-target="#event2">

                    Sports Meet

                </button>

            </h2>

            <div
                id="event2"
                class="accordion-collapse collapse">

                <div class="accordion-body">

                    Annual sports competition details.

                </div>

            </div>

        </div>

    </div>

</div>

<!-- Bootstrap JS Bundle -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
