<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Exercise 13</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">

    <h1 class="text-center text-primary mb-5">
        Bootstrap Colors and Backgrounds
    </h1>

    <!-- Exercise 13.1 -->

    <h2 class="mb-4">
        Dashboard Cards
    </h2>

    <div class="row">

        <div class="col-md-3">

            <div class="bg-primary text-white p-4 text-center rounded">

                <h4>Events</h4>
                <p>25 Active Events</p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="bg-success text-white p-4 text-center rounded">

                <h4>Members</h4>
                <p>120 Registered</p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="bg-warning p-4 text-center rounded">

                <h4>Pending</h4>
                <p>15 Requests</p>

            </div>

        </div>

        <div class="col-md-3">

            <div class="bg-danger text-white p-4 text-center rounded">

                <h4>Alerts</h4>
                <p>3 Notifications</p>

            </div>

        </div>

    </div>

    <hr class="my-5">

    <!-- Exercise 13.2 -->

    <h2 class="mb-4">
        Gradient Background Example
    </h2>

    <div class="bg-dark bg-gradient text-white p-5 rounded text-center">

        <h3>Community Event Portal</h3>

        <p>
            Welcome to Bootstrap Gradient Background Example
        </p>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
